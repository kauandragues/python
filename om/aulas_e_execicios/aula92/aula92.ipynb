   "source": [
    "# Aula 92\n",
    "\n",
    "## Yield from"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "30dcd213",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1\n",
      "2\n",
      "3\n",
      "4\n",
      "5\n",
      "6\n"
     ]
    }
   ],
   "source": [
    "def gen1():\n",
    "    yield 1\n",
    "    yield 2\n",
    "    yield 3\n",
    "\n",
    "def gen2(gen):\n",
    "    yield from gen()\n",
    "    yield 4\n",
    "    yield 5\n",
    "    yield 6\n",
    "\n",
    "gen = gen2(gen1)\n",
    "print(next(gen))\n",
    "print(next(gen))\n",
    "print(next(gen))\n",
    "print(next(gen))\n",
    "print(next(gen))\n",
    "print(next(gen))\n"
   ]
  }
 ],
